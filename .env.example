# Arquivo de configuração de ambiente do backend PHP.
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env — ele contém credenciais sensíveis.
#
# Aspas simples ou duplas ao redor do valor são opcionais, mas
# recomendadas quando o valor contiver espaços ou caracteres especiais.
# Exemplo: DB_PASSWORD="minha=senha#secreta"

DB_HOSTNAME=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=classetech_teste
DB_CHARSET=utf8
